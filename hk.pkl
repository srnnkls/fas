amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

local goGlobs = List("**/*.go", "**/go.mod", "**/go.sum")

// `go fix ./...` — Go 1.23+ modernizer. Safe, behavior-preserving; rewrites
// obsolete idioms (pre-generics, pre-slices/maps stdlib, etc.). Runs in
// fix-capable hooks only; no check command (fix-only step).
local gofix: Step = new {
  glob = goGlobs
  workspace_indicator = "go.mod"
  fix = "cd {{workspace}} && go fix ./..."
  stomp = true
}

local linters = new Mapping<String, Step> {
  ["gofmt"] = Builtins.go_fmt
  ["govet"] = Builtins.go_vet
  ["golangci-lint"] = Builtins.golangci_lint
  ["gomod-tidy"] = Builtins.gomod_tidy
}

local runners = new Mapping<String, Step> {
  ["build"] {
    glob = goGlobs
    workspace_indicator = "go.mod"
    check = "cd {{workspace}} && go build ./..."
    stomp = true
  }
  // Also replays the fuzz seed corpora (e.g. FuzzRecursiveFlag) as the
  // deterministic gate; live `-fuzz` deepening is manual/out-of-gate
  // (`mise run test-fuzz`).
  ["test"] {
    glob = goGlobs
    workspace_indicator = "go.mod"
    check = "cd {{workspace}} && go test ./..."
    stomp = true
  }
}

local scrut: Step = new {
  glob = List("**/*.go", "**/go.mod", "**/go.sum", "tests/**")
  workspace_indicator = "go.mod"
  check = "cd {{workspace}} && mise run test-integration"
  stomp = true
}

// Fix-only steps: gofmt in fix mode + go fix modernizer.
local fixers = new Mapping<String, Step> {
  ["gofmt-fix"] = (linters["gofmt"]) {
    check = null
    check_list_files = null
    check_diff = null
  }
  ["gofix"] = gofix
}

hooks {
  ["pre-commit"] {
    fix = true
    stage = true
    fail_on_fix = true
    stash = "git"
    steps = new {
      ...fixers
      ...linters
      ...runners
    }
  }
  ["check"] {
    steps = new {
      ...linters
      ...runners
      ["scrut"] = scrut
    }
  }
  ["lint"] {
    steps = linters
  }
  ["test"] {
    steps = new {
      ["test"] = (runners["test"]) {}
      ["scrut"] = scrut
    }
  }
  ["fix"] {
    fix = true
    steps = fixers
  }
}
